# ---------------------------------------------------------------------------
# next-book-app — copy to `.env.local` (local dev) or set in Docker / hosting.
# Values shown are defaults or placeholders; see `src/server/env.ts` for parsing.
# ---------------------------------------------------------------------------

# --- Server (Next.js / custom server) ---
NODE_ENV=development
PORT=3000
# Bind address for `server.ts` when used (Docker dev sets 0.0.0.0)
# HOSTNAME=0.0.0.0

# --- PostgreSQL (Drizzle + app; matches docker-compose DB service) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=reactauth
DB_PASSWORD=reactauth
DB_NAME=reactauth

# --- File uploads (use absolute path in Docker, e.g. /app/uploads) ---
UPLOAD_ROOT=

# --- JWT & refresh cookie (`src/server/env.ts`) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_COOKIE=refresh_token
# Milliseconds; default 7 days if unset
# REFRESH_COOKIE_MAX_AGE_MS=604800000

# --- CORS: empty = allow all (dev convenience). Production: single origin or comma list ---
# FRONTEND_ORIGIN=https://your-app.example

# --- Bootstrap: comma-separated emails get admin role on first provisioning ---
# BOOTSTRAP_ADMIN_EMAILS=admin@example.com

# --- Public client: leave empty to use same-origin `/api`. Set full URL if API is separate ---
# NEXT_PUBLIC_API_BASE_URL=

# --- Optional features (omit to disable related UI/API behavior) ---
# Book AI layout assistant (`src/server/services/book-ai.service.ts`)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Stock photos in book AI / templates (`src/server/services/pexels.service.ts`)
# PEXELS_API_KEY=

# Weather widget (`src/server/services/weather.service.ts`)
# OPENWEATHERMAP_API_KEY=

# News widget (`src/server/services/news.service.ts`)
# NEWSAPI_KEY=

# --- Docker / webpack dev only (Next reads this; docker-compose.dev.yml sets it) ---
# WATCHPACK_POLLING=true
